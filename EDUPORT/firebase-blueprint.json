{
  "entities": {
    "User": {
      "title": "User",
      "description": "A student user in the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth UID." },
        "name": { "type": "string", "description": "The student's full name." },
        "referenceId": { "type": "string", "description": "The student's unique reference ID." },
        "course": { "type": "string", "description": "The course the student is enrolled in." },
        "email": { "type": "string", "format": "email", "description": "The student's email address." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created." }
      },
      "required": ["uid", "name", "referenceId", "course", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A project created by a student.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique project ID." },
        "studentUid": { "type": "string", "description": "The UID of the student who owns this project." },
        "title": { "type": "string", "description": "Project title." },
        "description": { "type": "string", "description": "Project description." },
        "technologies": { "type": "array", "items": { "type": "string" }, "description": "List of technologies used." },
        "imageUrl": { "type": "string", "format": "uri", "description": "URL to the project image." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the project was created." }
      },
      "required": ["studentUid", "title", "description", "technologies"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Student profile information."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Student projects."
    }
  }
}
